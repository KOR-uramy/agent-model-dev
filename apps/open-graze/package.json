{
  "name": "open-graze",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "sync:feed": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; curl -sS -X POST -H \"Authorization: Bearer ${RALPH_FEED_SYNC_SECRET}\" -H \"Content-Type: application/json\" -d \"{\\\"tail\\\":8000}\" \"http://localhost:${PORT:-3000}/api/ralph/sync-jsonl\"'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
