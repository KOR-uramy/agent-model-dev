# JSONL → SQLite 동기화 (POST /api/ralph/sync-jsonl). dev 서버 띄운 뒤: npm run sync:feed -w open-graze
RALPH_FEED_SYNC_SECRET="로컬에서만 쓰는 긴 임의 문자열"

# —— 로컬 Ralph / OpenGraze 대시보드 (`/`, `/api/ralph/events`) ——
# 키 이름·우선순위: packages/ralph-workspace-sdk/README.md
# RALPH_WORKSPACE=/Users/you/dev/agent-model-dev
# RALPH_EVENTS_JSONL=/path/to/.ralph/events.jsonl
# RALPH_USD_PER_MILLION_EST_TOKENS=15

# —— DB (워크스페이스·Auth·수집) ——
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — https://authjs.dev/getting-started/providers/google
# SessionProvider가 항상 /api/auth/session 을 호출하므로 필수. 비우면 개발에서만 임시 secret + 콘솔 경고.
AUTH_SECRET="openssl rand -base64 32 결과를 넣으세요"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 토스페이먼츠 v2 (결제 표준)
# https://docs.tosspayments.com/guides/v2/get-started/llms-guide
NEXT_PUBLIC_TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# Stripe (레거시)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 텔레그램 웹훅 → IngestedEvent
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_WORKSPACE_MAP=""
TELEGRAM_REPLY_ACK="0"
