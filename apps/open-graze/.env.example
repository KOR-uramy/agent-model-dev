# JSONL → SQLite 동기화 (POST /api/ralph/sync-jsonl). dev 서버 띄운 뒤: npm run sync:feed -w open-graze
RALPH_FEED_SYNC_SECRET="로컬에서만 쓰는 긴 임의 문자열"

# —— 로컬 Ralph / OpenGraze 대시보드 (`/`, `/api/ralph/events`) ——
# 키 이름·우선순위: packages/ralph-workspace-sdk/README.md
# RALPH_WORKSPACE=/Users/you/dev/agent-model-dev
# RALPH_EVENTS_JSONL=/path/to/.ralph/events.jsonl
# RALPH_USD_PER_MILLION_EST_TOKENS=15

# —— 수집 API (`POST /api/v1/events`) ——
# 본문 최대 바이트(기본 262144 = 256KiB). 상한 10MiB까지 허용.
# INGEST_MAX_BODY_BYTES="262144"

# —— DB (워크스페이스·Auth·수집) ——
# 스키마가 `prisma/schema.prisma`이면 상대 경로는 prisma/ 폴더 기준 → `prisma/dev.db`
DATABASE_URL="file:./dev.db"

# Auth.js — 이메일·비밀번호(Credentials, DB의 User.passwordHash). JWT 세션.
# SessionProvider가 항상 /api/auth/session 을 호출하므로 필수. 비우면 개발에서만 임시 secret + 콘솔 경고.
AUTH_SECRET="openssl rand -base64 32 결과를 넣으세요"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
# 테스트 계정: npm run db:migrate -w open-graze && npm run db:seed -w open-graze
# 기본 이메일 dev@opengraze.local / 비밀번호 opengraze-dev (SEED_USER_* 로 덮어쓰기 가능)
# SEED_USER_EMAIL=""
# SEED_USER_PASSWORD=""

# 토스페이먼츠 v2 (결제 표준)
# https://docs.tosspayments.com/guides/v2/get-started/llms-guide · https://docs.tosspayments.com/llms.txt
# 결제위젯 연동 키 → NEXT_PUBLIC_TOSS_CLIENT_KEY, 시크릿 키 → TOSS_SECRET_KEY
NEXT_PUBLIC_TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
# 구독 단건 결제 금액(KRW, 기본 100). 운영 시 상품에 맞게 조정.
# TOSS_SUBSCRIPTION_AMOUNT_KRW="9900"
# 웹훅 HMAC용(미설정 시 TOSS_SECRET_KEY 사용). 개발자센터 웹훅 전용 시크릿이 있으면 여기에.
# TOSS_WEBHOOK_SECRET=""

# Stripe (레거시)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── 외부 앱·다른 리포가 “이” OpenGraze로 이벤트 보낼 때 (선택, 런타임에만) ──
# 대시보드「루트 .env용 snippet」은 보통 아래 세 줄만 복사합니다. 로그인·세션 경고를 없애려면 위쪽 AUTH_SECRET 은 그대로 필요합니다.
# OpenGraze 서버용 .env 가 아니라, 클라이언트 앱/CI 쪽 .env 에 두는 값과 이름을 맞추면 LLM 가이드와 일치합니다.
# OPENGRAZE_PLATFORM_URL="http://localhost:3000"
# OPENGRAZE_PLATFORM_API_KEY="og_live_..."
# OPENGRAZE_WORKSPACE_SLUG="my-workspace-slug"
# 전체 연동 문서: 저장소 루트 docs/opengraze-llms-guide.md · 배포 후 GET /llms.txt

# 텔레그램 웹훅 → IngestedEvent
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_WORKSPACE_MAP=""
TELEGRAM_REPLY_ACK="0"
