{
  "name": "agent-model-dev",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "prepare": "npm run postinstall -w open-graze --if-present",
    "build": "npm run build -w ralph-workspace-sdk && npm run build -w open-graze",
    "test:compile": "npm run build",
    "test": "npm run test:compile",
    "kill:3000": "sh scripts/kill-port.sh 3000",
    "dev": "sh scripts/dev-open-graze.sh",
    "dev:open-graze": "sh scripts/dev-open-graze.sh",
    "platform:self-test": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; exec node scripts/platform-self-test.mjs'",
    "runtime:smoke": "node scripts/runtime-smoke.mjs",
    "sync:feed": "npm run sync:feed -w open-graze"
  }
}
