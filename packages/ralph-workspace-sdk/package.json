{
  "name": "ralph-workspace-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Ralph events.jsonl·텔레메트리·OpenGraze 수집 HTTP(createOpenGrazeIngestClient)·Next API 핸들러 — 타 앱에서 플랫폼에 붙일 때 재사용",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./platform": {
      "types": "./dist/platform-ingest.d.ts",
      "default": "./dist/platform-ingest.js"
    }
  },
  "files": ["dist"],
  "bin": {
    "openg-graze-git-commit": "./dist/git-hook.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "next": "15.5.15",
    "typescript": "^5"
  }
}
