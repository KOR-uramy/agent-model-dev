{
  "name": "ralph-workspace-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Ralph 루프 events.jsonl 읽기·요약·Next.js API 핸들러 — 새 워크스페이스에서 env만 맞추면 연동",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    }
  },
  "files": ["dist"],
  "bin": {
    "openg-graze-git-commit": "./dist/git-hook.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "next": "15.5.15",
    "typescript": "^5"
  }
}
